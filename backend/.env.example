# MongoDB Atlas — Database → Connect → Drivers → copy connection string.
# Replace <password> with your DB user password (URL-encode special characters).
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/taskflow?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d
NODE_ENV=development

# If Node fails with querySrv ECONNREFUSED on Windows, use Atlas "standard connection string"
# (mongodb://host1:27017,host2:27017,.../taskflow?ssl=true&authSource=admin&retryWrites=true&w=majority).

# Optional: local MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017/taskflow
